{
  "name": "writing-continuation-agent",
  "version": "1.0.0",
  "description": "AI writing continuation agent with evaluator feedback loop",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "example": "tsx src/index.ts --input \"The old lighthouse keeper climbed the spiral staircase as he had done every evening for thirty years. Tonight, however, something was different. The light at the top flickered in a pattern he had never seen before.\" --verbose",
    "type-check": "tsc --noEmit",
    "marker-writer": "tsx src/marker_writer/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:marker-writer": "tsx tests/test-prompts.ts --all",
    "test:basic_position": "tsx tests/test-prompts.ts --category BASIC_POSITION",
    "test:mid_sentence": "tsx tests/test-prompts.ts --category MID_SENTENCE",
    "test:between_sections": "tsx tests/test-prompts.ts --category BETWEEN_SECTIONS",
    "test:mid_paragraph": "tsx tests/test-prompts.ts --category MID_PARAGRAPH",
    "test:multi_language": "tsx tests/test-prompts.ts --category MULTI_LANGUAGE",
    "test:content_type": "tsx tests/test-prompts.ts --category CONTENT_TYPE",
    "test:paired_markers": "tsx tests/test-prompts.ts --category PAIRED_MARKERS",
    "test:edge_case": "tsx tests/test-prompts.ts --category EDGE_CASE",
    "test:voice_matching": "tsx tests/test-prompts.ts --category VOICE_MATCHING",
    "test:single": "tsx tests/test-prompts.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.2.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}
